# ── Telegram-бот LIFE OS — переменные окружения ─────────────────────────────
# Скопируй в .env и заполни значения. НЕ коммить .env!

# Обязательные ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAF...     # от @BotFather
OPENAI_API_KEY=sk-proj-...              # тот же что в Vercel
TELEGRAM_WEBAPP_URL=https://life-os-chi-rose.vercel.app

# Опциональные (нужны для сохранения данных в общую базу) ──────────────────────
SUPABASE_URL=https://ВАШ_ПРОЕКТ.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service_role ключ (НЕ anon!)
